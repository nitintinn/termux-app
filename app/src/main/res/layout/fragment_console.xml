<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/black">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:contentScrim="@color/black"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:titleEnabled="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A Termux"
                    android:textColor="#00FFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Cloud Console"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/console_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="System Ready • 0 Active Sessions"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="92dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="MANAGED SERVICES"
                android:textColor="#50FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_quick_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="SYSTEM OVERVIEW"
                android:textColor="#50FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <!-- CPU Usage Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:strokeWidth="1dp"
                app:strokeColor="#30FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CPU Load"
                            android:textColor="#00FFFF"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tv_cpu_stats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:text="0.00"
                            android:textColor="#80FFFFFF"
                            android:textSize="12sp" />
                    </RelativeLayout>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_cpu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:trackColor="#20FFFFFF"
                        app:indicatorColor="#00E5FF"
                        app:trackThickness="6dp"
                        app:trackCornerRadius="3dp"
                        android:progress="10" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- RAM Usage Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:strokeWidth="1dp"
                app:strokeColor="#30FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Memory (RAM)"
                            android:textColor="#00FFFF"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tv_ram_stats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:text="0 / 0 GB"
                            android:textColor="#80FFFFFF"
                            android:textSize="12sp" />
                    </RelativeLayout>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_ram"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:trackColor="#20FFFFFF"
                        app:indicatorColor="#00FFFF"
                        app:trackThickness="6dp"
                        app:trackCornerRadius="3dp"
                        android:progress="30" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Storage Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:strokeWidth="1dp"
                app:strokeColor="#30FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Internal Storage"
                            android:textColor="#00FFFF"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tv_storage_stats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:text="0 / 0 GB"
                            android:textColor="#80FFFFFF"
                            android:textSize="12sp" />
                    </RelativeLayout>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_storage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:trackColor="#20FFFFFF"
                        app:indicatorColor="#00E5FF"
                        app:trackThickness="6dp"
                        app:trackCornerRadius="3dp"
                        android:progress="60" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
