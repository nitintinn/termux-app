<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A Termux Settings"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:paddingBottom="24dp" />

        <!-- Cloudflared Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#1AFFFFFF"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cloudflare Tunnel"
                android:textColor="#00FFFF"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tunnel Token"
                android:textColorHint="#80FFFFFF"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_tunnel_token"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_toggle_tunnel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start Tunnel"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tv_tunnel_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: Stopped"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:paddingTop="8dp" />
        </LinearLayout>

        <!-- Stats Server Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#1AFFFFFF"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Console Server (Port 3000)"
                android:textColor="#00FFFF"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_stats_server"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Run in background"
                android:textColor="@color/white" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_native_settings"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Advanced Termux Settings"
            android:textColor="#00E5FF"
            app:strokeColor="#00E5FF"
            android:layout_marginTop="24dp" />

    </LinearLayout>
</ScrollView>
